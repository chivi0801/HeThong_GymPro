@startuml

' === CẤU HÌNH HIỂN THỊ ERD ===
!theme plain
hide circle
hide methods
skinparam linetype ortho

' Cấu hình màu sắc cho đẹp
skinparam class {
    BackgroundColor White
    BorderColor #333333
    ArrowColor #333333
}

skinparam titleFontSize 24
title Hệ Thống Quản Lý Phòng Gym - Phiên Bản Rút Gọn (Chỉ Chủ Phòng Gym)

scale 2

' === ĐỊNH NGHĨA CÁC THỰC THỂ (ENTITIES) ===

entity "users" as users {
    *id : BIGINT UNSIGNED <<PK>>
    --
    username : VARCHAR(255)
    password : VARCHAR(255)
    email : VARCHAR(255)
    role : ENUM('owner')
    name : VARCHAR(255)
    phone : VARCHAR(15)
    created_at : TIMESTAMP
    updated_at : TIMESTAMP
}

entity "members" as members {
    *id : BIGINT UNSIGNED <<PK>>
    --
    name : VARCHAR(255)
    phone : VARCHAR(15)
    email : VARCHAR(255)
    gender : ENUM('male', 'female', 'other')
    date_of_birth : DATE
    address : VARCHAR(255)
    status : ENUM('active', 'inactive')
    registration_date : DATE
    notes : TEXT
    created_at : TIMESTAMP
    updated_at : TIMESTAMP
}

entity "packages" as packages {
    *id : BIGINT UNSIGNED <<PK>>
    --
    name : VARCHAR(255)
    description : TEXT
    duration_months : INT
    price : DECIMAL(15,2)
    max_sessions : INT
    is_active : TINYINT(1)
    created_at : TIMESTAMP
    updated_at : TIMESTAMP
}

entity "subscriptions" as subscriptions {
    *id : BIGINT UNSIGNED <<PK>>
    --
    *member_id : BIGINT UNSIGNED <<FK>>
    *package_id : BIGINT UNSIGNED <<FK>>
    start_date : DATE
    end_date : DATE
    payment_status : ENUM('paid', 'unpaid', 'partial')
    total_amount : DECIMAL(15,2)
    paid_amount : DECIMAL(15,2)
    notes : TEXT
    created_at : TIMESTAMP
    updated_at : TIMESTAMP
}

entity "inventories" as inventories {
    *id : BIGINT UNSIGNED <<PK>>
    --
    name : VARCHAR(255)
    description : TEXT
    quantity : INT
    price : DECIMAL(15,2)
    supplier : VARCHAR(255)
    stock_in_date : DATE
    created_at : TIMESTAMP
    updated_at : TIMESTAMP
}

entity "sales" as sales {
    *id : BIGINT UNSIGNED <<PK>>
    --
    *member_id : BIGINT UNSIGNED <<FK>>
    *inventory_id : BIGINT UNSIGNED <<FK>>
    quantity : INT
    total_price : DECIMAL(15,2)
    sale_date : DATE
    payment_status : ENUM('paid', 'unpaid')
    notes : TEXT
    created_at : TIMESTAMP
    updated_at : TIMESTAMP
}

entity "payments" as payments {
    *id : BIGINT UNSIGNED <<PK>>
    --
    *related_id : BIGINT UNSIGNED <<FK>> (subscription or sale)
    related_type : ENUM('subscription', 'sale')
    amount : DECIMAL(15,2)
    payment_method : ENUM('cash', 'card', 'transfer')
    payment_date : DATE
    transaction_id : VARCHAR(255)
    status : ENUM('completed', 'pending', 'failed')
    created_at : TIMESTAMP
    updated_at : TIMESTAMP
}

' === QUAN HỆ (RELATIONSHIPS) ===

' Users (Owner) - Members (1 - N): Owner manages members
users ||..o{ members : "manages"

' Members - Subscriptions (1 - N)
members ||..o{ subscriptions : "has"

' Packages - Subscriptions (1 - N)
packages ||..o{ subscriptions : "applied to"

' Members - Sales (1 - N)
members ||..o{ sales : "makes"

' Inventories - Sales (1 - N)
inventories ||..o{ sales : "sold in"

' Subscriptions/Sales - Payments (1 - N): Polymorphic relationship for revenues
subscriptions ||..o{ payments : "has"
sales ||..o{ payments : "has"

@enduml